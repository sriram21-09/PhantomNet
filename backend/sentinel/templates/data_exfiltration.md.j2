    -T fields -e dns.qry.name | sort | uniq -c | sort -rn | head -50 \
    > /tmp/dns_queries.txt

  # Calculate subdomain entropy (Python)
  python3 -c "
  import math, collections
  with open('/tmp/dns_queries.txt') as f:
      for line in f:
          count, name = line.strip().split(None, 1)
          sub = name.split('.')[0]
          freq = collections.Counter(sub)
          h = -sum(v/len(sub)*math.log2(v/len(sub)) for v in freq.values())
          if h > 3.5:  # High entropy = likely encoded data
              print(f'HIGH ENTROPY ({h:.2f}): {name}')
  "

  # Check for known DNS tunnelling tool fingerprints (iodine, dnscat2)
  grep -E "iodine|dnscat|dns2tcp" {{ ids_alert_log | default("/var/log/snort/alert") }}
