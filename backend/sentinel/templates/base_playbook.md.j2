### SIEM Queries

```
{%- if attack_pattern | default("") in ["brute_force", "failed_login"] %}
index=auth-logs source_ip="{{ source_ip | default("*") }}" event_type="failed_login"
  | stats count by source_ip, username
  | where count > {{ failed_logins_threshold | default(20) }}
{%- elif attack_pattern | default("") in ["port_scan", "scan"] %}
index=netflow-* src_ip="{{ source_ip | default("*") }}"
  | stats dc(dest_port) as unique_ports by src_ip
  | where unique_ports > {{ port_count_threshold | default(50) }}
{%- elif attack_pattern | default("") in ["credential_reuse", "honeytoken"] %}
index=honeypot-events token_id="{{ token_id | default("*") }}" NOT honeypot=true
  | table _time, source_ip, token_id, target_host
{%- elif attack_pattern | default("") in ["distributed_attack", "distributed"] %}
index=netflow-* dest_ip="{{ target_ip | default("*") }}"
  | stats dc(src_ip) as distinct_sources by dest_ip
  | where distinct_sources > {{ distinct_ips_threshold | default(5) }}
{%- else %}
index={{ siem_index | default("siem-alerts-*") }} attack_pattern="{{ attack_pattern | default("*") }}"
  | table _time, source_ip, target_ip, event_type, severity
{%- endif %}
```

